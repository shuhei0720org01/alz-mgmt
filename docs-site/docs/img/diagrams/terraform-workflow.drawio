<mxfile host="VS Code" generator="diagram-forge">
  <diagram id="terraform-workflow" name="Terraform Workflow">
    <mxGraphModel dx="1000" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="500">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Title -->
        <mxCell id="title" value="🌱 Terraform の3ステップ" 
                style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1" 
                vertex="1" parent="1">
          <mxGeometry x="350" y="10" width="300" height="40" as="geometry"/>
        </mxCell>

        <!-- Step 1: Write -->
        <mxCell id="step1" value="" 
                style="swimlane;horizontal=1;startSize=35;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;fontSize=14;fontStyle=1" 
                vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="220" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="step1_title" value="✍️ 1. Write（書く）" 
                style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1" 
                vertex="1" parent="step1">
          <mxGeometry x="10" y="5" width="200" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="code_file" value="main.tf&#xa;variables.tf&#xa;outputs.tf" 
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontFamily=Courier New" 
                vertex="1" parent="step1">
          <mxGeometry x="60" y="45" width="100" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="step1_desc" value="HCLでインフラを定義" 
                style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11" 
                vertex="1" parent="step1">
          <mxGeometry x="10" y="130" width="200" height="30" as="geometry"/>
        </mxCell>

        <!-- Step 2: Plan -->
        <mxCell id="step2" value="" 
                style="swimlane;horizontal=1;startSize=35;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;fontSize=14;fontStyle=1" 
                vertex="1" parent="1">
          <mxGeometry x="350" y="80" width="220" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="step2_title" value="📝 2. Plan（計画）" 
                style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1" 
                vertex="1" parent="step2">
          <mxGeometry x="10" y="5" width="200" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="terminal" value="$ terraform plan&#xa;&#xa;+ resource_group&#xa;+ virtual_network&#xa;~ firewall" 
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#263238;strokeColor=#666666;fontSize=10;fontFamily=Courier New;fontColor=#ffffff;align=left" 
                vertex="1" parent="step2">
          <mxGeometry x="30" y="45" width="160" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="step2_desc" value="変更内容を事前確認" 
                style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11" 
                vertex="1" parent="step2">
          <mxGeometry x="10" y="145" width="200" height="30" as="geometry"/>
        </mxCell>

        <!-- Step 3: Apply -->
        <mxCell id="step3" value="" 
                style="swimlane;horizontal=1;startSize=35;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;fontSize=14;fontStyle=1" 
                vertex="1" parent="1">
          <mxGeometry x="640" y="80" width="300" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="step3_title" value="🚀 3. Apply（適用）" 
                style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1" 
                vertex="1" parent="step3">
          <mxGeometry x="10" y="5" width="200" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="azure_icon" value="Azure" 
                style="aspect=fixed;html=1;points=[];align=center;image;fontSize=11;image=img/lib/azure2/general/Resource_Groups.svg;verticalLabelPosition=bottom;verticalAlign=top;" 
                vertex="1" parent="step3">
          <mxGeometry x="30" y="50" width="60" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="vnet_icon" value="VNet" 
                style="aspect=fixed;html=1;points=[];align=center;image;fontSize=11;image=img/lib/azure2/networking/Virtual_Networks.svg;verticalLabelPosition=bottom;verticalAlign=top;" 
                vertex="1" parent="step3">
          <mxGeometry x="120" y="50" width="60" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="fw_icon" value="Firewall" 
                style="aspect=fixed;html=1;points=[];align=center;image;fontSize=11;image=img/lib/azure2/networking/Firewalls.svg;verticalLabelPosition=bottom;verticalAlign=top;" 
                vertex="1" parent="step3">
          <mxGeometry x="210" y="50" width="60" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="step3_desc" value="実際にAzureにリソース作成" 
                style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11" 
                vertex="1" parent="step3">
          <mxGeometry x="50" y="145" width="200" height="30" as="geometry"/>
        </mxCell>

        <!-- Arrows -->
        <mxCell id="arrow1" value="" 
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#6c8ebf;endArrow=classic;endFill=1;" 
                edge="1" parent="1" source="step1" target="step2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="arrow2" value="" 
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#d6b656;endArrow=classic;endFill=1;" 
                edge="1" parent="1" source="step2" target="step3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- State file -->
        <mxCell id="state" value="💾 terraform.tfstate&#xa;（現在の状態を記憶）" 
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1" 
                vertex="1" parent="1">
          <mxGeometry x="400" y="320" width="200" height="50" as="geometry"/>
        </mxCell>
        
        <mxCell id="state_arrow" value="状態を保存" 
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#b85450;dashed=1;endArrow=classic;endFill=1;" 
                edge="1" parent="1" source="step3" target="state">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Benefits -->
        <mxCell id="benefits" value="✨ メリット: バージョン管理 / レビュー可能 / 再利用 / 自動化" 
                style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;fontColor=#6c8ebf" 
                vertex="1" parent="1">
          <mxGeometry x="250" y="400" width="500" height="30" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
