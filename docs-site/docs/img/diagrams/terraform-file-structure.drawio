                <mxCell id="tfvars-role" value="変数の値を設定" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="1290" y="400" width="190" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="tfvars-desc" value="&#xa;• 環境ごとの値を記載&#xa;• プロジェクト名&#xa;• リージョン&#xa;• インスタンスサイズ&#xa;&#xa;💡 実際の値を入れる&#xa;　.auto.tfvarsなら自動読込" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#666666;" parent="1" vertex="1">
                    <mxGeometry x="1290" y="425" width="180" height="105" as="geometry"/>
                </mxCell>
                <mxCell id="example-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#FFB900;strokeWidth=2;" parent="1" vertex="1">
                    <mxGeometry x="40" y="580" width="1440" height="360" as="geometry"/>
                </mxCell>
                <mxCell id="example-title" value="💻 実際のコード例で理解しよう" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;fontColor=#FFB900;" parent="1" vertex="1">
                    <mxGeometry x="60" y="595" width="400" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="ex1-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E81123;strokeWidth=2;" parent="1" vertex="1">
                    <mxGeometry x="60" y="640" width="340" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="ex1-title" value="variables.tf" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=15;fontStyle=1;fontColor=#E81123;" parent="1" vertex="1">
                    <mxGeometry x="70" y="650" width="320" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="ex1-code" value="variable &quot;project_name&quot; {&#xa;  type        = string&#xa;  description = &quot;プロジェクト名&quot;&#xa;}&#xa;&#xa;variable &quot;location&quot; {&#xa;  type        = string&#xa;  description = &quot;リージョン&quot;&#xa;  default     = &quot;japaneast&quot;&#xa;}&#xa;&#xa;variable &quot;tags&quot; {&#xa;  type        = map(string)&#xa;  description = &quot;タグ&quot;&#xa;  default     = {}&#xa;}" style="text;html=1;strokeColor=none;fillColor=#F5F5F5;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;fontFamily=Courier New;fontColor=#333333;spacing=5;" parent="1" vertex="1">
                    <mxGeometry x="70" y="680" width="320" height="230" as="geometry"/>
                </mxCell>
                <mxCell id="ex2-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F65314;strokeWidth=2;" parent="1" vertex="1">
                    <mxGeometry x="420" y="640" width="320" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="ex2-title" value="terraform.tfvars" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=15;fontStyle=1;fontColor=#F65314;" parent="1" vertex="1">
                    <mxGeometry x="430" y="650" width="300" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="ex2-code" value="project_name = &quot;my-azure-project&quot;&#xa;&#xa;location = &quot;japaneast&quot;&#xa;&#xa;tags = {&#xa;  Environment = &quot;dev&quot;&#xa;  ManagedBy   = &quot;Terraform&quot;&#xa;  Owner       = &quot;DevTeam&quot;&#xa;}&#xa;&#xa;&#xa;&#xa;⬆️ 左で定義した変数に&#xa;　実際の値を入れている" style="text;html=1;strokeColor=none;fillColor=#F5F5F5;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;fontFamily=Courier New;fontColor=#333333;spacing=5;" parent="1" vertex="1">
                    <mxGeometry x="430" y="680" width="300" height="230" as="geometry"/>
                </mxCell>
                <mxCell id="ex3-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#00BCF2;strokeWidth=2;" parent="1" vertex="1">
                    <mxGeometry x="760" y="640" width="350" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="ex3-title" value="locals.tf" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=15;fontStyle=1;fontColor=#00BCF2;" parent="1" vertex="1">
                    <mxGeometry x="770" y="650" width="330" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="ex3-code" value="locals {&lt;br&gt;  # 共通の命名規則&lt;br&gt;  resource_prefix = &quot;${var.project_name}-${var.location}&quot;&lt;br&gt;  &lt;br&gt;  # リソースグループ名&lt;br&gt;  rg_name = &quot;${local.resource_prefix}-rg&quot;&lt;br&gt;  &lt;br&gt;  # タグを拡張&lt;br&gt;  common_tags = merge(&lt;br&gt;    var.tags,&lt;br&gt;    {&lt;br&gt;      Project = var.project_name&lt;br&gt;    }&lt;br&gt;  )&lt;br&gt;}&lt;br&gt;⬆️ 変数を組み合わせて新しい値を作成" style="text;html=1;strokeColor=none;fillColor=#F5F5F5;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;fontFamily=Courier New;fontColor=#333333;spacing=5;" parent="1" vertex="1">
                    <mxGeometry x="770" y="675" width="330" height="230" as="geometry"/>
                </mxCell>
                <mxCell id="ex4-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7FBA00;strokeWidth=2;" parent="1" vertex="1">
                    <mxGeometry x="1130" y="640" width="330" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="ex4-title" value="main.tf" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=15;fontStyle=1;fontColor=#7FBA00;" parent="1" vertex="1">
                    <mxGeometry x="1140" y="650" width="310" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="ex4-code" value="resource &quot;azurerm_resource_group&quot; &quot;main&quot; {&#xa;  name     = local.rg_name&#xa;  location = var.location&#xa;  tags     = local.common_tags&#xa;}&#xa;&#xa;resource &quot;azurerm_virtual_network&quot; &quot;main&quot; {&#xa;  name                = &quot;${local.resource_prefix}-vnet&quot;&#xa;  location            = azurerm_resource_group.main.location&#xa;  resource_group_name = azurerm_resource_group.main.name&#xa;  address_space       = [&quot;10.0.0.0/16&quot;]&#xa;  tags                = local.common_tags&#xa;}&#xa;&#xa;⬆️ ローカル変数や変数を使ってリソース作成" style="text;html=1;strokeColor=none;fillColor=#F5F5F5;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;fontFamily=Courier New;fontColor=#333333;spacing=5;" parent="1" vertex="1">
                    <mxGeometry x="1140" y="680" width="310" height="230" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>