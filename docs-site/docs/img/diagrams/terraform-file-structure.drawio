                <mxCell id="tfvars-title" value="✍️ terraform.tfvars" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;fontColor=#F65314;" parent="1" vertex="1">
